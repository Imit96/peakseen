# =============================================================================
# PeakSeen — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.
# =============================================================================

# --- Public (exposed to browser) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
NEXT_PUBLIC_SITE_URL=https://peakseen.com
NEXT_PUBLIC_CAL_USERNAME=peakseen

# --- Supabase (server only) ---
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# --- Resend (transactional email) ---
RESEND_API_KEY=re_your_resend_api_key_here

# --- Brevo (marketing email) ---
BREVO_API_KEY=xkeysib-your_brevo_api_key_here

# --- OpenAI (Brand Name Generator) ---
OPENAI_API_KEY=sk-your_openai_api_key_here

# --- Upstash Redis (rate limiting) ---
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here

# --- Lemon Squeezy (payments + digital delivery) ---
LEMON_SQUEEZY_WEBHOOK_SECRET=your_webhook_secret_here

# --- Vercel (auto-configured on Vercel) ---
# VERCEL_URL is automatically set by Vercel
